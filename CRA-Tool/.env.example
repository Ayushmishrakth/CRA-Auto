# ============================================================
# CRA Tool — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ── App ──────────────────────────────────────────────────────
APP_NAME=CRA Backend
APP_VERSION=2.0.0
# Enable verbose error responses and auto-reload (disable in production)
DEBUG=True
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CRA_FRONTEND_URL=http://localhost:3000


# ── Database ─────────────────────────────────────────────────
# SQLite for local dev; swap to postgresql+asyncpg://... for production
DATABASE_URL=sqlite:///./cra.db


# ── Redis / Celery ───────────────────────────────────────────
# Redis must be running before starting Celery or the backend
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to True to run tasks synchronously (no Celery worker needed in dev)
CELERY_TASK_ALWAYS_EAGER=False
# Maximum seconds a single assessment task may run before being killed
CELERY_TASK_TIME_LIMIT_SECONDS=900
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=840


# ── Auth / JWT ───────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
# How long CRA access tokens remain valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# How long CRA refresh tokens remain valid (days)
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Azure / Microsoft ────────────────────────────────────────
# Client ID of your CRA App Registration in Azure Portal
# This is used for: Graph API calls AND validating Microsoft ID tokens at login
AZURE_CLIENT_ID=your-azure-client-id-here
# Set only if your frontend SPA app registration differs from the backend app.
# If omitted, AZURE_CLIENT_ID is used as the accepted Microsoft ID token audience.
AZURE_LOGIN_CLIENT_ID=your-azure-client-id-here
# Use "common" for multi-tenant (recommended), or a specific tenant GUID
AZURE_TENANT_ID=common
AZURE_AUTHORITY=https://login.microsoftonline.com/common
# Client secret from Azure Portal > App Registration > Certificates & Secrets
AZURE_CLIENT_SECRET=your-client-secret-here
# Redirect URI registered in Azure Portal under the SPA platform
# Must match exactly: http://localhost:3000 (no trailing slash, no path)
AZURE_REDIRECT_URI=http://localhost:3000/tenant/deployment-success


# ── Organization ─────────────────────────────────────────────
# Displayed on generated PDF/Word reports
ORGANIZATION_NAME=Your Organization Name


# ── Assessment ───────────────────────────────────────────────
# Root directory for assessment artifact files (CSV evidence, etc.)
ASSESSMENT_STORAGE_DIR=storage/assessments
# Enable deployment pre-flight checks and automatic error recovery
DEPLOYMENT_VALIDATION_ENABLED=true
DEPLOYMENT_AUTO_RECOVERY=true


# ── Report Generation ────────────────────────────────────────
# Where generated PDF/Word reports are saved
REPORT_OUTPUT_DIR=storage/reports
# Path to the Word template used for DOCX report generation
CRA_WORD_TEMPLATE_PATH=app/services/reporting/templates/AAA Legal Process Copilot Readiness Assessment Report.docx


# ── PowerShell Auth Modes ────────────────────────────────────
# Controls how PowerShell collectors authenticate to Microsoft services.
# Options:
#   skip   — collector is skipped silently (no browser popup, no score impact)
#   device — use device code flow; run Connect-ExchangeOnline manually first
#   token  — use CRA_EXCHANGE_ACCESS_TOKEN env var (advanced)
#
# Exchange Online, Teams, and Purview require delegated (user) auth —
# they cannot use app-only client credentials flow.
# Set to "device" and pre-authenticate in a PS terminal to collect data from these services.
CRA_EXCHANGE_AUTH_MODE=skip
CRA_TEAMS_AUTH_MODE=skip
CRA_PURVIEW_AUTH_MODE=skip
